<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme accompanies the image defined in drawable/launch_background.xml. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Show a splash screen on the activity. Automatically removed when
             the first frame is drawn. -->
        <item android:windowBackground>@drawable/launch_background</item>
    </style>
    <!-- Theme to apply after the launch screen is dismissed and Flutter is ready. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item android:windowBackground>?android:colorBackground</item>
    </style>
</resources>
